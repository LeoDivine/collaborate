generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  fullName      String
  userName      String?   @unique
  timezone      String?
  lastLogin     DateTime?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspaces Workspace[]
  members    Member[]

  accounts Account[]

  joinRequests     JoinRequest[] @relation("RequestUser")
  reviewedRequests JoinRequest[] @relation("ReviewUser")

  @@map("users")
}

model Workspace {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  mode         DeskMode
  industryType String?
  teamSize     String?
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdById  String

  members  Member[]
  requests JoinRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspaces")
}

model Member {
  id          String         @id @default(uuid())
  user        User           @relation(fields: [userId], references: [id])
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])
  workspaceId String
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  role        WorkspaceRoles

  @@unique([userId, workspaceId])
  @@map("members")
}

model JoinRequest {
  id         String        @id @default(uuid())
  email      String
  fullName   String
  inviteCode String?       @unique
  createdAt  DateTime      @default(now())
  status     RequestStatus @default(PENDING)
  message    String?

  reviewedById String?
  reviewedBy   User?    @relation("ReviewUser", fields: [reviewedById], references: [id])
  reviewedAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  user   User   @relation("RequestUser", fields: [userId], references: [id])
  userId String

  @@unique([email, workspaceId])
  @@map("join-requests")
}

enum DeskMode {
  WORKSPACE
  INDIVIDUAL
}

enum WorkspaceRoles {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectAccess {
  PROJECT_LEAD
  PROJECT_MANAGER
  CONTRIBUTER
  VIEWER
}

enum RequestStatus {
  PENDING
  ACCEPTED
}
